<input type="submit" name="issue_book" value="Issue Book">

</form>
<?php
if(isset($_POST['issue_book'])){
$book_id=$_POST['book_id'];
$student=$_POST['student'];
$issue=$_POST['issue_date'];
$return=$_POST['return_date'];
mysqli_query($conn,"INSERT INTO
issue_books(book_id,student_name,issue_date,return_date)
VALUES('$book_id','$student','$issue','$return')");
echo "Book Issued Successfully";
}
?>
<hr>
<h2>Issued Books</h2>
<table border="1">
<tr>
<th>ID</th>
<th>Book ID</th>
<th>Student</th>
<th>Issue Date</th>
<th>Return Date</th>
<th>Fine</th>
<th>Return</th>
</tr>
<?php
$result=mysqli_query($conn,"SELECT * FROM issue_books");
while($row=mysqli_fetch_assoc($result)){

$id=$row['id'];
$return_date=$row['return_date'];
$today=date("Y-m-d");
$fine=0;
if($today>$return_date){
$late_days=(strtotime($today)-strtotime($return_date))/(60*60*24);
$fine=$late_days*5;
mysqli_query($conn,"UPDATE issue_books SET fine='$fine' WHERE id='$id'");
}
echo "<tr>";
echo "<td>".$row['id']."</td>";
echo "<td>".$row['book_id']."</td>";
echo "<td>".$row['student_name']."</td>";
echo "<td>".$row['issue_date']."</td>";
echo "<td>".$row['return_date']."</td>";
echo "<td>".$fine."</td>";
echo "<td><a href='library.php?return=".$row['id']."'>Return</a></td>";
echo "</tr>";
}
?>
</table>
<?php
if(isset($_GET['return'])){
$id=$_GET['return'];
mysqli_query($conn,"DELETE FROM issue_books WHERE id='$id'");
echo "Book Returned";
}
?>

